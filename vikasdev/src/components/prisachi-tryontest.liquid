{% assign tryon_block_id = 'prisachi-tryon-' | append: product.id %}

<div id="{{ tryon_block_id }}" class="prisachi-tryon">
  <div class="prisachi-tryon__card">
    <p class="prisachi-tryon__eyebrow">Virtual Try On</p>
    <h3 class="prisachi-tryon__title">See This Product On You</h3>
    <p class="prisachi-tryon__copy">
      Upload your image and preview this product directly on the product page.
    </p>

    <div class="prisachi-tryon__actions">
      <input
        id="{{ tryon_block_id }}-file"
        class="prisachi-tryon__file"
        type="file"
        accept="image/*"
      >
      <button
        id="{{ tryon_block_id }}-button"
        class="prisachi-tryon__button"
        type="button"
      >
        Upload Image
      </button>
    </div>

    <p id="{{ tryon_block_id }}-status" class="prisachi-tryon__status">
      Best results come from a clear portrait or full-body image.
    </p>

    <div class="prisachi-tryon__grid">
      <div class="prisachi-tryon__panel">
        <p class="prisachi-tryon__panel-title">Your Image</p>
        <div id="{{ tryon_block_id }}-preview-wrap" class="prisachi-tryon__placeholder">
          Upload an image to preview it here.
        </div>
      </div>

      <div class="prisachi-tryon__panel">
        <p class="prisachi-tryon__panel-title">Try-On Result</p>
        <div id="{{ tryon_block_id }}-result-wrap" class="prisachi-tryon__placeholder">
          Your generated result will appear here.
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .prisachi-tryon {
    margin-top: 24px;
  }

  .prisachi-tryon__card {
    padding: 24px;
    border: 1px solid #eadfd5;
    border-radius: 20px;
    background: linear-gradient(180deg, #fffaf7 0%, #fff4ee 100%);
  }

  .prisachi-tryon__eyebrow {
    margin: 0 0 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #a25f43;
  }

  .prisachi-tryon__title {
    margin: 0 0 8px;
    font-size: 24px;
    line-height: 1.15;
    color: #2a1d1a;
  }

  .prisachi-tryon__copy,
  .prisachi-tryon__status,
  .prisachi-tryon__panel-title {
    color: #6f5f5a;
  }

  .prisachi-tryon__copy {
    margin: 0 0 16px;
  }

  .prisachi-tryon__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .prisachi-tryon__file {
    max-width: 260px;
  }

  .prisachi-tryon__button {
    padding: 12px 18px;
    border: none;
    border-radius: 999px;
    background: #2a1d1a;
    color: #ffffff;
    font-weight: 600;
    cursor: pointer;
  }

  .prisachi-tryon__button[disabled] {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .prisachi-tryon__status {
    margin: 0 0 18px;
    font-size: 14px;
  }

  .prisachi-tryon__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .prisachi-tryon__panel {
    padding: 16px;
    border-radius: 16px;
    background: #ffffff;
    border: 1px solid #f0e7e1;
  }

  .prisachi-tryon__panel-title {
    margin: 0 0 10px;
    font-size: 14px;
    font-weight: 600;
  }

  .prisachi-tryon__placeholder {
    min-height: 320px;
    border-radius: 14px;
    background: #f7efe9;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 16px;
    overflow: hidden;
  }

  .prisachi-tryon__image {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 14px;
    display: block;
  }

  .prisachi-tryon__status.is-error {
    color: #b42318;
  }

  .prisachi-tryon__status.is-success {
    color: #166534;
  }

  @media screen and (max-width: 749px) {
    .prisachi-tryon__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function () {
    const root = document.getElementById({{ tryon_block_id | json }});
    if (!root) return;

    /*
      Replace this with your deployed Render backend URL.
      Example: https://your-app-name.onrender.com/try-on
    */
    const TRY_ON_API_URL = "https://YOUR-RENDER-BACKEND.onrender.com/try-on";

    const productData = {
      id: {{ product.id | json }},
      name: {{ product.title | json }},
      type: {{ product.type | json }},
      tags: {{ product.tags | json }},
      image: {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }},
    };

    const fileInput = document.getElementById("{{ tryon_block_id }}-file");
    const button = document.getElementById("{{ tryon_block_id }}-button");
    const status = document.getElementById("{{ tryon_block_id }}-status");
    const previewWrap = document.getElementById("{{ tryon_block_id }}-preview-wrap");
    const resultWrap = document.getElementById("{{ tryon_block_id }}-result-wrap");

    function guessGender(product) {
      const text = [
        product.name || "",
        product.type || "",
        ...(Array.isArray(product.tags) ? product.tags : []),
      ].join(" ").toLowerCase();

      if (text.includes("men") || text.includes("male") || text.includes("boy")) {
        return "men";
      }

      return "women";
    }

    function guessGarmentType(product) {
      const text = [
        product.name || "",
        product.type || "",
        ...(Array.isArray(product.tags) ? product.tags : []),
      ].join(" ").toLowerCase();

      if (
        text.includes("jeans") ||
        text.includes("pants") ||
        text.includes("trouser") ||
        text.includes("bottom") ||
        text.includes("legging")
      ) {
        return "lower_body";
      }

      if (
        text.includes("dress") ||
        text.includes("gown") ||
        text.includes("saree") ||
        text.includes("lehenga") ||
        text.includes("full body")
      ) {
        return "full_body";
      }

      return "upper_body";
    }

    function setStatus(message, tone) {
      status.textContent = message;
      status.classList.remove("is-error", "is-success");
      if (tone) status.classList.add(tone);
    }

    function renderImage(container, src, alt) {
      container.innerHTML = "";
      const image = document.createElement("img");
      image.className = "prisachi-tryon__image";
      image.src = src;
      image.alt = alt;
      container.appendChild(image);
    }

    button.addEventListener("click", async function () {
      const file = fileInput.files && fileInput.files[0];

      if (!file) {
        setStatus("Please choose an image first.", "is-error");
        return;
      }

      if (!productData.image || productData.image === "https:") {
        setStatus("This product does not have a valid product image.", "is-error");
        return;
      }

      const previewUrl = URL.createObjectURL(file);
      renderImage(previewWrap, previewUrl, "Uploaded preview");

      const garmentType = guessGarmentType(productData);
      const gender = guessGender(productData);

      const formData = new FormData();
      formData.append("image", file);
      formData.append("productName", productData.name || "Product");
      formData.append("clothImage", productData.image);
      formData.append("garmentDescription", productData.name || productData.type || "fashion garment");
      formData.append("garmentType", garmentType);
      formData.append("gender", gender);
      formData.append("category", productData.type || "fashion");

      button.disabled = true;
      setStatus("Generating try-on result...", "");
      resultWrap.textContent = "Generating result...";

      try {
        const response = await fetch(TRY_ON_API_URL, {
          method: "POST",
          body: formData,
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.message || data.error || "Try-on failed");
        }

        if (!data.outputUrl) {
          throw new Error("No try-on image returned from API.");
        }

        renderImage(resultWrap, data.outputUrl, "Try-on result");
        setStatus("Try-on generated successfully.", "is-success");
      } catch (error) {
        resultWrap.textContent = "Unable to generate try-on result.";
        setStatus(error.message || "Something went wrong.", "is-error");
      } finally {
        button.disabled = false;
      }
    });
  })();
</script>
